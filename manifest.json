{
  "manifest_version": 3,
  "name": "FeedWriter",
  "version": "2.1.0",
  "description": "Tóm tắt bài viết bằng AI với tiêu đề hook mạnh, chỉnh sửa & copy thành status. Chế bài affiliate. Dịch từ Anh-Việt.",
  "author": "Le An (anlvdt)",
  "homepage_url": "https://github.com/anlvdt/fb-post-summarizer",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "*://*.shope.ee/*",
    "*://*.shopee.vn/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://m.facebook.com/*",
        "https://*.threads.net/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://www.reddit.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://m.facebook.com/*",
        "https://*.threads.net/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://www.reddit.com/*"
      ],
      "js": ["translate.js"],
      "css": ["translate.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "summarize-shortcut": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Tóm tắt nội dung văn bản bôi đen"
    },
    "affiliate-shortcut": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Chế bài Affiliate từ văn bản bôi đen"
    }
  }
}